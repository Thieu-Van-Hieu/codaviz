# ── Whitelist approach: block tất cả, cho phép từng thứ cụ thể ───────────────

/*
!documents/
!README.md
!CHANGELOG.md
!LICENSE.md
!.gitignore
!code/

code/*
!code/frontend/

# ── Frontend ──────────────────────────────────────────────────────────────────

code/frontend/*
!code/frontend/public/
!code/frontend/src/
!code/frontend/index.html
!code/frontend/eslint.config.js
!code/frontend/package.json
!code/frontend/package-lock.json
!code/frontend/pnpm-lock.yaml
!code/frontend/tsconfig.json
!code/frontend/tsconfig.app.json
!code/frontend/tsconfig.node.json
!code/frontend/vite.config.ts
!code/frontend/.editorconfig
!code/frontend/README.md

# ── Block dù nằm ở đâu ───────────────────────────────────────────────────────

# Dependencies
**/node_modules/

# Build output
**/dist/
**/dist-ssr/
**/build/

# Vite cache
**/.vite/
**/*.local

# TypeScript build info
**/*.tsbuildinfo

# Env files — không bao giờ commit secret keys
**/.env
**/.env.local
**/.env.*.local

# Editor temp files
**/.DS_Store
**/Thumbs.db
**/*.swp
**/*.swo
**/~$*

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/pnpm-debug.log*

# Test coverage
**/coverage/
